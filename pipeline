plugin: pipeline

pipeline {
    agent any       #docker or any
    
    stages {
        stage('Build') {
            steps {
                echo 'Hello world!' 
            }
        }
        stage('test') {
            steps {
                echo 'Testing!' 
            }
        }
        stage('Deploy') {
            steps {
                echo 'Deployinh!' 
            }
        }
    }
    
}



